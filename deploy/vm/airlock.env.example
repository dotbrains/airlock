# Install to /etc/airlock.env (chmod 600). Shared by both systemd units.
# Generate the API token with: openssl rand -hex 32

# Bearer token for the dashboard + management API. Required — the host is
# networked.
AIRLOCK_API_TOKEN=

# Shared secret gating /api/internal/prune (must match for api + worker).
AIRLOCK_INTERNAL_TOKEN=

# Public base URL + host, as seen by clients behind your TLS proxy.
AIRLOCK_PUBLIC_BASE_URL=https://airlock.example.com
AIRLOCK_SESSION_HOST=airlock.example.com

# VNC password baked into browser containers.
AIRLOCK_VNC_PASSWORD=change-me

# Default session lifetime in seconds (clamped 60–86400).
AIRLOCK_DEFAULT_TTL_SECONDS=1800

# Worker prune interval in milliseconds (minimum 5000).
AIRLOCK_CLEANUP_INTERVAL_MS=30000
