# Install to /etc/airlock.env (chmod 600). Shared by both systemd units.
# Fill in the REQUIRED secrets below before starting the services — empty
# tokens leave the management API and prune endpoint unauthenticated on a
# networked host. Generate each with: openssl rand -hex 32

# REQUIRED. Bearer token for the dashboard + management API. An empty value
# leaves the API and dashboard open to anyone who can reach the host.
AIRLOCK_API_TOKEN=replace-with-openssl-rand-hex-32

# REQUIRED. Shared secret gating /api/internal/prune (must match for api +
# worker). An empty value lets anyone force-delete active sessions.
AIRLOCK_INTERNAL_TOKEN=replace-with-openssl-rand-hex-32

# Public base URL + host, as seen by clients behind your TLS proxy.
AIRLOCK_PUBLIC_BASE_URL=https://airlock.example.com
AIRLOCK_SESSION_HOST=airlock.example.com

# VNC password baked into browser containers. Set a strong value.
AIRLOCK_VNC_PASSWORD=replace-with-openssl-rand-hex-16

# Default session lifetime in seconds (clamped 60–86400).
AIRLOCK_DEFAULT_TTL_SECONDS=1800

# Worker prune interval in milliseconds (minimum 5000).
AIRLOCK_CLEANUP_INTERVAL_MS=30000
