# Copy to .env next to docker-compose.yml and fill in. Generate the API token
# with: openssl rand -hex 32

# Bearer token for the dashboard + management API. Required once the API is
# reachable beyond loopback; leave blank for a purely local run.
AIRLOCK_API_TOKEN=

# Shared secret gating /api/internal/prune (must match for api + worker).
AIRLOCK_INTERNAL_TOKEN=local-dev-token

# Group id of the host Docker socket so the non-root container can drive it.
# Linux: stat -c '%g' /var/run/docker.sock   Docker Desktop: 0
DOCKER_GID=0

# Public base URL used to build /s/:id launch links.
AIRLOCK_PUBLIC_BASE_URL=http://localhost:8787

# Host clients use to reach the spawned browser containers.
AIRLOCK_SESSION_HOST=localhost

# VNC password baked into browser containers.
AIRLOCK_VNC_PASSWORD=change-me

# Default session lifetime in seconds (clamped 60–86400).
AIRLOCK_DEFAULT_TTL_SECONDS=1800

# Worker prune interval in milliseconds (minimum 5000).
AIRLOCK_CLEANUP_INTERVAL_MS=30000
