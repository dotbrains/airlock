# Airlock environment sample. Copy to .env for local development:
#   cp .env.sample .env
# Every variable has a default — override only what you need. See
# docs/configuration.md for the full reference.

# --- API ---
AIRLOCK_PORT=8787
# Interface the API binds. Defaults to all interfaces; set 127.0.0.1 to keep it
# loopback-only on a shared host.
AIRLOCK_BIND_HOST=0.0.0.0
AIRLOCK_PUBLIC_BASE_URL=http://localhost:8787
AIRLOCK_SESSION_HOST=localhost
AIRLOCK_DOCKER_SOCKET_PATH=/var/run/docker.sock
# Remote Docker engine instead of the local socket (managed-PaaS deploys).
# AIRLOCK_DOCKER_HOST=tcp://your-engine:2376
# AIRLOCK_DOCKER_CERT_PATH=/etc/airlock/docker-certs
AIRLOCK_DEFAULT_TTL_SECONDS=1800
AIRLOCK_DEFAULT_BROWSER=chromium
# Fallback VNC password. Each session also gets its own random password; this
# is only used by older containers that predate per-session passwords.
AIRLOCK_VNC_PASSWORD=change-me
# Bearer token gating the dashboard + management API. Leave blank for a purely
# local run; set it (openssl rand -hex 32) before exposing the API.
AIRLOCK_API_TOKEN=
# Absolute path to a built dashboard to serve from the API. The production
# image sets this automatically; leave unset in local dev (use `bun dev:web`).
# AIRLOCK_WEB_DIR=

# --- Per-session container limits (0 = no limit) ---
# AIRLOCK_SESSION_MEMORY_BYTES=2147483648
# AIRLOCK_SESSION_CPUS=2
# AIRLOCK_SESSION_PIDS_LIMIT=512
# AIRLOCK_SHM_SIZE_BYTES=1073741824

# --- Network isolation ---
# Attach sessions to a dedicated, inter-container-isolated bridge network.
AIRLOCK_NETWORK_ISOLATION=true
AIRLOCK_NETWORK_NAME=airlock
# Route all browser egress through an operator-controlled proxy.
# AIRLOCK_EGRESS_PROXY=http://proxy.internal:3128

# --- Limits (0 disables) ---
AIRLOCK_MAX_SESSIONS=25
AIRLOCK_RATE_LIMIT_WINDOW_MS=60000
AIRLOCK_RATE_LIMIT_MAX=30

# --- Browser images (Kasm) ---
AIRLOCK_IMAGE_CHROMIUM=kasmweb/chromium:1.18.0
AIRLOCK_IMAGE_CHROME=kasmweb/chrome:1.18.0
AIRLOCK_IMAGE_FIREFOX=kasmweb/firefox:1.18.0
AIRLOCK_IMAGE_EDGE=kasmweb/edge:1.18.0
AIRLOCK_IMAGE_BRAVE=kasmweb/brave:1.18.0
AIRLOCK_IMAGE_VIVALDI=kasmweb/vivaldi:1.18.0
AIRLOCK_IMAGE_TOR=kasmweb/tor-browser:1.18.0

# --- Worker ---
AIRLOCK_API_BASE_URL=http://localhost:8787
AIRLOCK_CLEANUP_INTERVAL_MS=30000

# --- Shared (api + worker) ---
# Must match across both apps when set; gates POST /api/internal/prune.
AIRLOCK_INTERNAL_TOKEN=local-dev-token
