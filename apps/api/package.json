{
  "name": "@airlock/api",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "format": "prettier --write \"src/**/*.{ts,js}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js}\"",
    "build": "bun run --filter @airlock/shared build && tsc -p tsconfig.json",
    "dev": "bun --watch src/index.ts",
    "start": "bun dist/index.js",
    "typecheck": "bun run --filter @airlock/shared build && tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@airlock/shared": "workspace:*",
    "cors": "^2.8.5",
    "dockerode": "^4.0.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/dockerode": "^3.3.33",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8",
    "yaml": "^2.6.1"
  }
}
